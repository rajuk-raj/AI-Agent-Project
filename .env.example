# Template only. Copy to .env.local and put the real key there.
# This file IS committed to git - it must never contain a secret.
#
# The key is read ONLY by serverless functions in /api. It never reaches the browser.
# NOTE: the OpenAI API bills separately from ChatGPT Plus. A Plus subscription
# does not grant API access. Add credit at platform.openai.com/billing.

# !! Leave BLANK here. Real value goes in .env.local (gitignored).
OPENAI_API_KEY=

# Model IDs are set per-tool so cost/quality can be tuned without code changes.
# Verify current model names and prices at platform.openai.com/docs/models.
LLM_MODEL_DECOMPOSE=gpt-5-nano
LLM_MODEL_COMPETENCY=gpt-5-nano
LLM_MODEL_REWRITE=gpt-5-nano
LLM_MODEL_SCORE=gpt-5-nano
LLM_MODEL_QUESTIONS=gpt-5-nano

# Serper.dev - Google Search API, used to find a job description from a
# company + role. Free tier is 2,500 queries. Get a key at serper.dev.
# Optional: without it, you can still paste a JD by hand.
SERPER_API_KEY=

# Rate limiting. New accounts start on a low usage tier; check your limits at
# platform.openai.com/settings/organization/limits. Set to 0 to disable pacing.
LLM_MAX_RPM=0
LLM_MAX_RETRIES=4

# Reasoning models reject the temperature parameter. The smoke test detects
# this and tells you which value to use here.
LLM_OMIT_TEMPERATURE=false
